# Chorus — Environment Variables
# Copy this file to .env.local and fill in your Azure AI Foundry credentials

# ─── Endpoint 1: Australia East ───────────────────────────────
FOUNDRY_AUSTRALIAEAST_NAME=vd-foundry-project-resource
FOUNDRY_AUSTRALIAEAST_API_KEY=your-api-key-here

# ─── Endpoint 2: East US 2 ───────────────────────────────────
FOUNDRY_EASTUS2_NAME=vd-chats-resource
FOUNDRY_EASTUS2_API_KEY=your-api-key-here
